# Required for admin protection
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# Runtime storage mode (`supabase` for hosted, `local` for local fallback)
STORAGE_MODE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Klaviyo integration
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_LIST_ID=

# Optional: site base URL for canonical links
NEXT_PUBLIC_SITE_URL=https://diyesu.com
